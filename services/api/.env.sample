# Server
PORT=50051            # gRPC listen port (default: 50051)

# Logging
RUST_LOG=info         # Tracing filter — e.g. debug, warn, myfeed_api=debug (default: info)
LOG_FORMAT=           # Set to "json" for structured JSON logs; omit for plain text

# Auth
REQUIRE_AUTH=         # Set to "1" to enforce authorization header on all gRPC requests

# YouTube
YOUTUBE_API_KEY=      # YouTube Data API key; omit to run without YouTube (returns empty results)
